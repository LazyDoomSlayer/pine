#!/usr/bin/env php
<?php

declare(strict_types=1);

use Pine\Commands\RepositoriesListCommand;
use Pine\Commands\RepositoriesStatusCommand;
use Pine\Console\Application;
use Pine\Console\ApplicationHelpRenderer;
use Pine\Console\CommandRegistry;
use Pine\Console\Input;
use Pine\Console\Output;
use Pine\Container\Container;

require dirname(__DIR__) . '/vendor/autoload.php';

$container = new Container();

$commands = new CommandRegistry();
$commands->add(
    $container->get(RepositoriesListCommand::class),
);
$commands->add(
    $container->get(RepositoriesStatusCommand::class),
);


$output = new Output();

$application = new Application(
    commands: $commands,
    helpRenderer: new ApplicationHelpRenderer($output),
    output: $output,
);

$input = new Input($argv);

exit($application->run($input));
